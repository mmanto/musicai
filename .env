# ==========================================
# MusicAI - Variables de Entorno Centralizadas
# ==========================================
# Este archivo contiene las variables de entorno compartidas por todos los servicios
# Se referencia desde cada docker-compose.yml usando: env_file: ../.env

# ==========================================
# OLLAMA - LLM Service
# ==========================================
# Ollama corre en el HOST, accesible via host.docker.internal desde Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qcwind/qwen3-8b-instruct-Q4-K-M:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2048
OLLAMA_TIMEOUT=120

# ==========================================
# INFRAESTRUCTURA - RABBITMQ
# ==========================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==========================================
# INFRAESTRUCTURA - REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# INFRAESTRUCTURA - NEO4J
# ==========================================
# Credenciales - esto es lo único que Neo4j necesita como variables de entorno
NEO4J_USER=neo4j
NEO4J_PASSWORD=musicai_password

# Variables de conexión para aplicaciones (no son variables de Neo4j mismo)
# Se usan en los servicios para conectarse a Neo4j
NEO4J_HOST=neo4j
NEO4J_URI=bolt://neo4j:7687
