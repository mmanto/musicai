# MusicAI Preprocessing Service Configuration

# Service Info
SERVICE_NAME=preprocessing
SERVICE_VERSION=0.1.0

# API Configuration
REST_HOST=0.0.0.0
REST_PORT=8001
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PREFETCH_COUNT=10

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# Other Modules (gRPC endpoints)
MODEL_BASE_GRPC=model-base:50052
KNOWLEDGE_GRAPH_GRPC=knowledge-graph:50053
REASONING_GRPC=reasoning:50054

# Processing
AUDIO_CACHE_DIR=/app/cache
MAX_AUDIO_DURATION=600
SAMPLE_RATE=22050

# Tokenizer
BPE_VOCAB_SIZE=30000
MAX_SEQ_LENGTH=8192

# Feature Extraction
N_MELS=128
N_FFT=2048
HOP_LENGTH=512
