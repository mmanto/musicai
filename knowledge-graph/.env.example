# Service Configuration
SERVICE_NAME=knowledge-graph
SERVICE_VERSION=0.1.0

# REST API
REST_HOST=0.0.0.0
REST_PORT=8003

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50053

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=musicai_password
NEO4J_DATABASE=musicai

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# GNN Model
GNN_EMBEDDING_DIM=256
GNN_HIDDEN_DIM=512
GNN_NUM_LAYERS=3
GNN_DROPOUT=0.1
GNN_MODEL_PATH=./models/gnn_model.pt

# Processing
BATCH_SIZE=32
MAX_WORKERS=4
