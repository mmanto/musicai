# MusicAI Model Base Service Configuration

# Service Info
SERVICE_NAME=model-base
SERVICE_VERSION=0.1.0

# API Configuration
REST_HOST=0.0.0.0
REST_PORT=8002
GRPC_HOST=0.0.0.0
GRPC_PORT=50052

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PREFETCH_COUNT=5

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# Other Modules
PREPROCESSING_GRPC=preprocessing:50051
KNOWLEDGE_GRAPH_GRPC=knowledge-graph:50053
REASONING_GRPC=reasoning:50054

# Model Configuration
CHECKPOINT_DIR=/app/checkpoints

# Transformer Architecture
VOCAB_SIZE=30000
D_MODEL=512
N_HEADS=8
N_LAYERS=12
D_FF=2048
MAX_SEQ_LENGTH=8192
DROPOUT=0.1
MAX_RELATIVE_POSITION=512

# Generation
DEFAULT_TEMPERATURE=1.0
DEFAULT_TOP_K=50
DEFAULT_TOP_P=0.95
MAX_GENERATION_LENGTH=2048

# Device
DEVICE=cuda
USE_FP16=true
