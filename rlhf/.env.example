# Service Configuration
SERVICE_NAME=rlhf
SERVICE_VERSION=0.1.0

# REST API
REST_HOST=0.0.0.0
REST_PORT=8005

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50055

# Model Configuration
MODEL_BASE_URL=http://model-base:8002
PREPROCESSING_URL=http://preprocessing:8001
REASONING_URL=http://reasoning:8004

# Reward Model
REWARD_MODEL_PATH=./models/reward_model
REWARD_MODEL_TYPE=pairwise  # pairwise, pointwise, or ranking
REWARD_BATCH_SIZE=16
REWARD_MAX_LENGTH=2048

# Training Configuration
TRAINING_ALGORITHM=ppo  # ppo, dpo, or grpo
LEARNING_RATE=1e-5
BATCH_SIZE=8
GRADIENT_ACCUMULATION_STEPS=4
MAX_STEPS=10000
SAVE_STEPS=500
EVAL_STEPS=100
WARMUP_STEPS=100

# PPO Specific
PPO_EPOCHS=4
PPO_CLIP_RANGE=0.2
PPO_VALUE_COEF=0.1
PPO_ENTROPY_COEF=0.01

# DPO Specific
DPO_BETA=0.1
DPO_REFERENCE_FREE=false

# Evaluation
EVAL_BATCH_SIZE=4
HUMAN_EVAL_ENABLED=true
HUMAN_EVAL_SAMPLE_RATE=0.1

# Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=musicai-rlhf
USE_TENSORBOARD=true
TENSORBOARD_LOG_DIR=./runs

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# RabbitMQ Queues
QUEUE_RLHF_TRAIN=rlhf.train
QUEUE_RLHF_EVAL=rlhf.eval
QUEUE_RLHF_FEEDBACK=rlhf.feedback
EXCHANGE_RLHF=musicai.rlhf

# Active Learning
ACTIVE_LEARNING_ENABLED=true
UNCERTAINTY_THRESHOLD=0.7
DIVERSITY_SAMPLING=true

# Data
TRAINING_DATA_PATH=./data/training
FEEDBACK_DATA_PATH=./data/feedback
CHECKPOINT_DIR=./models/checkpoints

# Processing
MAX_WORKERS=4
GPU_ENABLED=true
MIXED_PRECISION=fp16  # fp16, bf16, or fp32
