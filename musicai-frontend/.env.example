# MusicAI Frontend Configuration

# Backend Selection
# Set to 'true' to use the new reasoning service (MusicAI)
# Set to 'false' to use the original musicaim backend
VITE_USE_REASONING_SERVICE=true

# Reasoning Service URL (MusicAI reasoning service)
# Default: http://localhost:8004
VITE_REASONING_API_URL=http://localhost:8004

# Original API Base URL (musicaim backend)
# Used when VITE_USE_REASONING_SERVICE=false
VITE_API_BASE_URL=http://localhost:8000
VITE_API_V1_PREFIX=/api/v1

# WebSocket URL (optional, for future features)
VITE_WS_URL=ws://localhost:8000/ws

# Feature Flags
VITE_ENABLE_CREATIVE_GENERATION=true
VITE_ENABLE_KNOWLEDGE_GRAPH=true
VITE_ENABLE_RLHF_FEEDBACK=false
