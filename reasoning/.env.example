# Service Configuration
SERVICE_NAME=reasoning
SERVICE_VERSION=0.1.0

# REST API
REST_HOST=0.0.0.0
REST_PORT=8004

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50054

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2048
OLLAMA_TIMEOUT=120

# Knowledge Graph
KNOWLEDGE_GRAPH_URL=http://localhost:8003
KNOWLEDGE_GRAPH_GRPC=localhost:50053

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# RabbitMQ Queues
QUEUE_REASONING_GENERATED=reasoning.generated
QUEUE_REASONING_VALIDATE=reasoning.validate
QUEUE_REASONING_RESPONSE=reasoning.response
EXCHANGE_REASONING=musicai.reasoning

# Chain of Thought
COT_MAX_STEPS=5
COT_TEMPERATURE=0.3
COT_USE_EXAMPLES=true

# Music21 Settings
MUSIC21_CACHE_DIR=./cache/music21
MUSIC21_USE_LILYPOND=false

# Processing
BATCH_SIZE=16
MAX_WORKERS=4
