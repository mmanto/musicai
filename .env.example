# MusicAI Stack - Environment Configuration
# Copy this file to .env and customize values as needed

# ============================================================================
# INFRASTRUCTURE
# ============================================================================

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Redis
REDIS_PORT=6379

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=musicai_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================================
# MICROSERVICES
# ============================================================================

# Preprocessing Service
PREPROCESSING_REST_PORT=8001
PREPROCESSING_GRPC_PORT=50051

# Model Base Service
MODEL_BASE_REST_PORT=8002
MODEL_BASE_GRPC_PORT=50052
MODEL_BASE_DEVICE=cpu
MODEL_BASE_USE_FP16=false

# Knowledge Graph Service
KNOWLEDGE_GRAPH_REST_PORT=8003
KNOWLEDGE_GRAPH_GRPC_PORT=50053
GNN_EMBEDDING_DIM=256
GNN_HIDDEN_DIM=512

# Reasoning Service
REASONING_REST_PORT=8004
REASONING_GRPC_PORT=50054
COT_MAX_STEPS=5
COT_TEMPERATURE=0.3

# RLHF Service
RLHF_REST_PORT=8005
RLHF_GRPC_PORT=50055
TRAINING_ALGORITHM=ppo
LEARNING_RATE=0.00001

# ============================================================================
# CHAT APPLICATION
# ============================================================================

# Backend API
CHAT_BACKEND_PORT=8000
LOG_LEVEL=info

# Frontend
CHAT_FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_REASONING_API_URL=http://localhost:8004
VITE_USE_REASONING_SERVICE=true
NODE_ENV=development

# ============================================================================
# OPTIONAL - GPU SUPPORT
# ============================================================================
# Uncomment these for GPU-accelerated services
# GPU_ENABLED=true
# CUDA_VISIBLE_DEVICES=0
